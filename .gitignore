#-------------------------
# Operating Specific Junk Files
#-------------------------

# OS X
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows image file caches
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msm
*.msp
*.lnk

# Linux
*~
.directory
.Trash-*

#-------------------------
# Environment / Secrets
#-------------------------
.env
.vagrant
Vagrantfile

#-------------------------
# CI4 Framework (встановлюється через Softaculous)
#-------------------------
system/

#-------------------------
# Vendor (Composer)
#-------------------------
vendor/

#-------------------------
# Writable (cache, logs, sessions)
#-------------------------
writable/cache/*
!writable/cache/index.html

writable/logs/*
!writable/logs/index.html

writable/session/*
!writable/session/index.html

writable/uploads/*
!writable/uploads/index.html

writable/debugbar/*
!writable/debugbar/index.html

php_errors.log

#-------------------------
# IDE / Editors
#-------------------------
.idea/
*.iml
.vscode/
*.sublime-workspace
*.sublime-project
.phpintel
/nbproject/

